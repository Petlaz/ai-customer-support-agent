# =============================================================================
# AI Customer Support Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Never commit .env to version control.
# =============================================================================

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Primary: OpenAI (recommended — most LangGraph examples target OpenAI)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
# Use gpt-4o-mini during development (cheap + fast)
# Switch to gpt-4o for production / evaluation runs
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional fallback: Anthropic (not required to get started)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Which provider to use: openai | anthropic
LLM_PROVIDER=openai

# ── Database ─────────────────────────────────────────────────────────────────
# Local development: SQLite (zero config, works out of the box)
DATABASE_URL=sqlite:///./data/support_agent.db

# Production: PostgreSQL on Amazon RDS — uncomment and fill in
# DATABASE_URL=postgresql://user:password@localhost:5432/support_agent

# ── Vector Store (ChromaDB) ───────────────────────────────────────────────────
CHROMA_PERSIST_PATH=./data/chroma_db

# ── Langfuse Observability ────────────────────────────────────────────────────
# Get your keys at https://cloud.langfuse.com → Project Settings
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# ── FastAPI Application ───────────────────────────────────────────────────────
APP_NAME=AI Customer Support Agent
APP_VERSION=0.1.0
APP_ENV=development
# Options: development | production
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-in-production
API_HOST=0.0.0.0
API_PORT=8000

# ── Agent Configuration ───────────────────────────────────────────────────────
# Confidence score below this → escalate to human review
CONFIDENCE_THRESHOLD=0.75
# Max policy document chunks to retrieve per query
MAX_RETRIEVAL_DOCS=5
# Max similar historical cases to retrieve
MAX_SIMILAR_CASES=3
# Refund amounts above this (USD) → escalate to human
HIGH_VALUE_REFUND_THRESHOLD=500.0

# ── Apache Airflow ────────────────────────────────────────────────────────────
AIRFLOW_HOME=./orchestration/airflow

# ── AWS (Production deployment only) ─────────────────────────────────────────
# Leave blank for local development
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
S3_BUCKET_NAME=your-s3-bucket-name
